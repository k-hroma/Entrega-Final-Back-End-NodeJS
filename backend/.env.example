# Puerto del servidor
PORT=3000

# Configuración de Firebase (SDK cliente - Firebase Web Config)
# Obtené estos valores en Firebase Console > Configuración del proyecto > General > Tus apps > Config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Secreto para firmar los JWT
# Generalo con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
